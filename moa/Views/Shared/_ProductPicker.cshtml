@{
    var title = (string?)ViewData["ProductPickerTitle"] ?? "اختر المنتجات";
    var pricePrefix = (string?)ViewData["ProductPickerPricePrefix"] ?? "";
}

<div class="rounded-3xl border border-slate-200 bg-white p-4">
    <div class="mb-3 flex items-center justify-between">
        <h2 class="text-sm font-bold text-slate-700">@title</h2>
        <div class="text-xs text-slate-500">اضغط + و -</div>
    </div>

    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        <template x-for="p in products" :key="p.ProductId">
            <div class="rounded-3xl border border-slate-200 bg-white p-4 shadow-sm">
                <div class="flex items-start justify-between gap-3">
                    <div>
                        <div class="font-semibold" x-text="p.ProductName"></div>
                        <div class="mt-1 text-xs text-slate-500" x-text="p.UnitName"></div>
                        @if (string.IsNullOrWhiteSpace(pricePrefix))
                        {
                            <div class="mt-1 text-xs text-slate-500" x-text="(p.UnitPrice == null ? '-' : p.UnitPrice)"></div>
                        }
                        else
                        {
                            <div class="mt-1 text-xs text-slate-500" x-text="'@pricePrefix' + (p.UnitPrice == null ? '-' : p.UnitPrice)"></div>
                        }
                        <div class="mt-1 text-xs text-slate-500" x-text="'المخزن: ' + (p.QuantityOnHand == null ? 0 : p.QuantityOnHand)"></div>
                        <div class="mt-1" x-show="p.LastRestockQuantity > 0 && (p.QuantityOnHand <= (p.LastRestockQuantity * 0.2))">
                            <span class="inline-flex items-center rounded-full bg-amber-50 px-2 py-1 text-xs font-semibold text-amber-700">قرب يخلص</span>
                        </div>
                    </div>
                    <div class="rounded-2xl bg-slate-100 px-3 py-1 text-sm font-bold" x-text="qty[p.ProductId] || 0"></div>
                </div>

                <div class="mt-3 grid grid-cols-2 gap-2">
                    <button type="button" class="h-11 rounded-2xl bg-indigo-600 text-white text-sm font-bold shadow-sm hover:bg-indigo-700" x-on:click="inc(p.ProductId)">+</button>
                    <button type="button" class="h-11 rounded-2xl border border-slate-200 bg-white text-sm font-bold text-slate-700 shadow-sm hover:bg-slate-50" x-on:click="dec(p.ProductId)">-</button>
                </div>
            </div>
        </template>
    </div>

    <div class="mt-4 text-xs text-slate-500" x-show="activeItems().length === 0">اختر على الأقل منتج واحد.</div>
</div>
