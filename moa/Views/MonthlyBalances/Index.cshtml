@model moa.Models.MonthlyBalancesIndexViewModel
@{
    ViewData["Title"] = "أرصدة الشهر";
}

<div class="mx-auto max-w-6xl">
    <div class="mb-6 flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
        <div>
            <h1 class="text-2xl font-bold">أرصدة الشهر</h1>
            <p class="text-sm text-slate-500">افتح رصيد شهري للبطاقات (مطلوب قبل السحب).</p>
        </div>

        <form method="get" class="flex flex-col gap-2 sm:flex-row sm:items-center">
            <input name="yearMonth" value="@Model.YearMonth" class="w-40 rounded-xl border border-slate-200 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-200" placeholder="YYYYMM" />
            <input name="search" value="@Model.Search" class="w-72 rounded-xl border border-slate-200 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-200" placeholder="بحث بالاسم أو رقم البطاقة" />
            <button type="submit" class="rounded-xl bg-slate-900 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-slate-800">عرض</button>
        </form>
    </div>

    <div class="rounded-3xl border border-slate-200 bg-white shadow-sm">
        <div class="border-b border-slate-200 px-6 py-4">
            <h2 class="text-sm font-bold text-slate-700">البطاقات (حتى 100)</h2>
        </div>

        @if (Model.Items.Count == 0)
        {
            <div class="px-6 py-8 text-sm text-slate-500">لا توجد بطاقات.</div>
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead class="bg-slate-50 text-slate-600">
                    <tr>
                        <th class="px-6 py-3 text-right font-semibold">الاسم</th>
                        <th class="px-6 py-3 text-right font-semibold">رقم البطاقة</th>
                        <th class="px-6 py-3 text-right font-semibold">الأفراد</th>
                        <th class="px-6 py-3 text-right font-semibold">رصيد الشهر</th>
                        <th class="px-6 py-3"></th>
                    </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                    @foreach (var c in Model.Items)
                    {
                        <tr class="hover:bg-slate-50">
                            <td class="px-6 py-4">@c.CustomerName</td>
                            <td class="px-6 py-4 font-mono">@c.CardNumber</td>
                            <td class="px-6 py-4">@c.MembersCount</td>
                            <td class="px-6 py-4">
                                @if (c.OpeningBalance.HasValue)
                                {
                                    <span class="font-semibold">@c.OpeningBalance</span>
                                }
                                else
                                {
                                    <span class="text-slate-400">غير محدد</span>
                                }
                            </td>
                            <td class="px-6 py-4 text-left">
                                <a class="rounded-xl bg-indigo-600 px-3 py-2 text-xs font-semibold text-white shadow-sm hover:bg-indigo-700" asp-action="Edit" asp-route-cardId="@c.CardId" asp-route-yearMonth="@Model.YearMonth">فتح/تعديل</a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
