@model List<moa.Models.ProductListItemViewModel>
@{
    ViewData["Title"] = "المنتجات";
}

<div class="mx-auto max-w-6xl">
    <div class="mb-6 flex items-center justify-between gap-3">
        <div>
            <h1 class="text-2xl font-bold">المنتجات</h1>
            <p class="text-sm text-slate-500">إدارة منتجات المحل ووحدات القياس.</p>
        </div>
        <a class="rounded-xl bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-700" asp-action="Create">إضافة منتج</a>
    </div>

    <div class="rounded-3xl border border-slate-200 bg-white shadow-sm">
        <div class="border-b border-slate-200 px-6 py-4">
            <h2 class="text-sm font-bold text-slate-700">القائمة</h2>
        </div>

        @if (Model.Count == 0)
        {
            <div class="px-6 py-8 text-sm text-slate-500">لا توجد منتجات.</div>
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead class="bg-slate-50 text-slate-600">
                    <tr>
                        <th class="px-6 py-3 text-right font-semibold">الاسم</th>
                        <th class="px-6 py-3 text-right font-semibold">الوحدة</th>
                        <th class="px-6 py-3 text-right font-semibold">السعر</th>
                        <th class="px-6 py-3 text-right font-semibold">المخزن</th>
                        <th class="px-6 py-3 text-right font-semibold">الحالة</th>
                        <th class="px-6 py-3"></th>
                    </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                    @foreach (var p in Model)
                    {
                        <tr class="hover:bg-slate-50">
                            <td class="px-6 py-4">@p.ProductName</td>
                            <td class="px-6 py-4">@p.UnitName</td>
                            <td class="px-6 py-4">@(p.CurrentUnitPrice?.ToString("0.##") ?? "-")</td>
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-2">
                                    <span class="font-semibold">@p.QuantityOnHand.ToString("0.###")</span>
                                    @if (p.IsLowStock)
                                    {
                                        <span class="inline-flex items-center rounded-full bg-amber-50 px-2 py-1 text-xs font-semibold text-amber-700">قرب يخلص</span>
                                    }
                                </div>
                            </td>
                            <td class="px-6 py-4">
                                @if (p.IsActive)
                                {
                                    <span class="inline-flex items-center rounded-full bg-emerald-50 px-2 py-1 text-xs font-semibold text-emerald-700">مفعل</span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center rounded-full bg-slate-100 px-2 py-1 text-xs font-semibold text-slate-700">غير مفعل</span>
                                }
                            </td>
                            <td class="px-6 py-4 text-left">
                                <a class="rounded-xl border border-slate-200 bg-white px-3 py-2 text-xs font-semibold text-slate-700 shadow-sm hover:bg-slate-50" asp-action="Edit" asp-route-id="@p.ProductId">تعديل</a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
