@model moa.Models.ReceiptCreateViewModel
@{
    ViewData["Title"] = "سحب جديد";
}

<script type="application/json" id="card-groups-json">@Html.Raw(System.Text.Json.JsonSerializer.Serialize((IEnumerable<dynamic>)ViewBag.CardGroups))</script>
<script type="application/json" id="products-json">@Html.Raw(System.Text.Json.JsonSerializer.Serialize((IEnumerable<dynamic>)ViewBag.Products))</script>

<div class="mx-auto max-w-5xl"
     x-data="{
        cardGroupsInitial: [],
        cardGroups: [],
        products: [],
        selectedCardId: @((Model.CardId ?? 0)),
        cardQuery: '',
        cardLookupTimer: null,
        qty: {},
        inc(pid){
            const p = (this.products || []).find(x => x.ProductId === pid);
            const onHand = p ? (p.QuantityOnHand || 0) : 0;
            const cur = (this.qty[pid] || 0);
            if (cur + 1 > onHand) return;
            this.qty[pid] = cur + 1;
        },
        dec(pid){ this.qty[pid] = Math.max(0, (this.qty[pid] || 0) - 1); },
        activeItems(){
            const items = [];
            for (const p of this.products) {
                const q = this.qty[p.ProductId] || 0;
                if (q > 0) items.push({ productId: p.ProductId, quantity: q });
            }
            return items;
        },
        lookupCards(){
            clearTimeout(this.cardLookupTimer);
            this.cardLookupTimer = setTimeout(() => {
                const q = (this.cardQuery || '').trim().toLowerCase();
                if (!q) {
                    this.cardGroups = this.cardGroupsInitial;
                    return;
                }

                this.cardGroups = (this.cardGroupsInitial || []).map(g => {
                    const cards = (g.Cards || []).filter(c =>
                        (c.CustomerName || '').toLowerCase().includes(q) || 
                        (c.CardNumber || '').toLowerCase().includes(q) ||
                        (c.Phone || '').toLowerCase().includes(q)
                    );
                    return { ...g, Cards: cards };
                }).filter(g => (g.Cards || []).length > 0);
            }, 150);
        }
     }"
     x-init="cardGroupsInitial = JSON.parse(document.getElementById('card-groups-json').textContent || '[]'); cardGroups = cardGroupsInitial; products = JSON.parse(document.getElementById('products-json').textContent || '[]');">
    <div class="mb-6 flex items-center justify-between gap-3">
        <div>
            <h1 class="text-2xl font-bold">سحب جديد</h1>
            <p class="text-sm text-slate-500">اختار البطاقة ثم اختار المنتجات.</p>
        </div>
        <a class="rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50" asp-controller="Receipts" asp-action="Index">سجل السحوبات</a>
    </div>

    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
        <form asp-action="Create" method="post" class="space-y-6">
            <div asp-validation-summary="All" class="rounded-2xl border border-rose-200 bg-rose-50 p-3 text-sm text-rose-700"></div>

            <input type="hidden" name="CardId" :value="selectedCardId" />

            <template x-for="(it, i) in activeItems()" :key="it.productId">
                <div>
                    <input type="hidden" :name="`Items[${i}].ProductId`" :value="it.productId" />
                    <input type="hidden" :name="`Items[${i}].Quantity`" :value="it.quantity" />
                </div>
            </template>

            <div class="grid gap-4 lg:grid-cols-2">
                <div class="rounded-3xl border border-slate-200 bg-white p-4">
                    <div class="mb-3 flex items-center justify-between">
                        <h2 class="text-sm font-bold text-slate-700">١) اختر البطاقة</h2>
                        <span class="text-xs text-slate-500" x-text="cardGroups.reduce((acc, g) => acc + (g.Cards ? g.Cards.length : 0), 0) + ' بطاقة'"></span>
                    </div>

                    <div class="mb-3">
                        <input type="text"
                               x-model="cardQuery"
                               x-on:input="lookupCards()"
                               class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-200"
                               placeholder="بحث بالاسم أو رقم البطاقة" />
                    </div>

                    <div class="space-y-3 max-h-[500px] overflow-y-auto pr-1 custom-scrollbar">
                        <template x-for="g in cardGroups" :key="g.GroupName">
                            <div class="rounded-2xl border border-slate-200 bg-slate-50 overflow-hidden">
                                <div class="border-b border-slate-200 bg-white/50 px-3 py-2 text-xs font-bold text-slate-700 flex justify-between items-center">
                                    <span x-text="g.GroupName"></span>
                                    <span class="text-slate-400 font-normal" x-text="(g.Cards || []).length + ' بطاقات'"></span>
                                </div>
                                <div class="grid gap-2 p-3 sm:grid-cols-1">
                                    <template x-for="c in (g.Cards || [])" :key="c.CardId">
                                        <div class="rounded-2xl border px-3 py-3 text-right text-sm shadow-sm transition-all duration-200 relative overflow-hidden group cursor-pointer"
                                             :class="selectedCardId === c.CardId ? 'border-indigo-600 bg-indigo-50 ring-1 ring-indigo-600' : 'border-slate-200 bg-white hover:border-indigo-300 hover:shadow-md'"
                                             x-on:click="selectedCardId = c.CardId">
                                            
                                            <!-- Selected Indicator -->
                                            <div class="absolute right-0 top-0 bottom-0 w-1.5 bg-indigo-600 transition-transform duration-300" 
                                                 :class="selectedCardId === c.CardId ? 'translate-x-0' : 'translate-x-full'"></div>
                                                 
                                            <div class="flex items-start justify-between gap-2">
                                                <div class="font-bold text-slate-800" :class="selectedCardId === c.CardId ? 'text-indigo-900' : ''" x-text="c.CustomerName"></div>
                                                <span class="inline-flex items-center justify-center rounded-lg bg-slate-100 px-2.5 py-1 font-mono text-xs font-semibold text-slate-600" 
                                                      :class="selectedCardId === c.CardId ? 'bg-indigo-100 text-indigo-700' : ''"
                                                      x-text="c.CardNumber"></span>
                                            </div>
                                            
                                            <div class="mt-2.5 flex items-center justify-between gap-4 text-xs">
                                                <div class="flex items-center gap-4">
                                                    <div class="flex items-center gap-1.5 text-slate-500">
                                                        <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                                                        <span x-text="(c.MembersCount || 0) + ' أفراد'"></span>
                                                    </div>
                                                    <template x-if="c.Phone">
                                                        <div class="flex items-center gap-1.5 text-slate-500">
                                                            <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                                                            <span x-text="c.Phone"></span>
                                                        </div>
                                                    </template>
                                                </div>
                                                
                                                <!-- Swipe Toggle -->
                                                <div x-data="{ isSwiped: c.IsSwipedInMachine }">
                                                    <button type="button" 
                                                            class="inline-flex items-center gap-1 rounded-md border px-2 py-1 text-[10px] font-bold transition-colors z-10 relative"
                                                            :class="isSwiped ? 'bg-indigo-600 border-indigo-600 text-white' : 'bg-slate-50 border-slate-200 text-slate-500 hover:bg-slate-100'"
                                                            x-on:click.stop="isSwiped = !isSwiped; c.IsSwipedInMachine = isSwiped; fetch('/CardGroups/ToggleSwipeStatus', { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': document.querySelector('input[name=__RequestVerificationToken]').value }, body: new URLSearchParams({ cardId: c.CardId, isSwiped: isSwiped }) })">
                                                        <span x-text="isSwiped ? '💳 انضربت' : '💳 لم تضرب'"></span>
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </template>
                                </div>
                            </div>
                        </template>
                    </div>

                    <div class="mt-3 text-xs text-slate-500" x-show="cardGroups.length === 0">لا توجد نتائج.</div>

                    <div class="mt-3 text-xs text-rose-600" x-show="selectedCardId === 0">لازم تختار بطاقة</div>
                </div>
            </div>

            @{ ViewData["ProductPickerTitle"] = "٢) اختر المنتجات"; ViewData["ProductPickerPricePrefix"] = ""; }
            <partial name="_ProductPicker" />

            <div class="flex items-center gap-3">
                <button type="submit"
                        class="rounded-xl bg-indigo-600 px-5 py-3 text-sm font-semibold text-white shadow-sm hover:bg-indigo-700"
                        :disabled="selectedCardId === 0 || activeItems().length === 0"
                        :class="(selectedCardId === 0 || activeItems().length === 0) ? 'opacity-50 cursor-not-allowed' : ''">
                    حفظ السحب
                </button>
                <a class="rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50" asp-controller="Cards" asp-action="Search">بحث بطاقة</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
