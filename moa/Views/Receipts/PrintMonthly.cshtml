@model moa.Models.PrintMonthlyViewModel
@using System.Globalization
@{
    Layout = null;
    ViewData["Title"] = "جرد الشهر";
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - @Model.StoreName</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = { theme: { extend: { fontFamily: { sans: ['Cairo','ui-sans-serif','system-ui'] } } } };
    </script>
    <style>
        @@media print {
            @@page { margin: 0.5cm; size: A4; }
            .no-print { display:none !important; }
            body { -webkit-print-color-adjust: exact; print-color-adjust: exact; background-color: white; }
            tbody tr, tbody td { height: 1.65cm !important; }
            td { vertical-align: middle; }
        }
    </style>
</head>
<body class="bg-white text-slate-900">
<div class="mx-auto max-w-6xl p-6 print:p-1 print:max-w-none print:m-0 w-full">
    <div class="no-print mb-4 flex items-center justify-between">
        <a class="rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50" href="javascript:window.close()">إغلاق</a>
        <div class="flex gap-2">
            <button class="rounded-xl bg-green-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-green-700" onclick="exportToWord('جرد_الشهر.doc')">تصدير إلى Word</button>
            <button class="rounded-xl bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-700" onclick="window.print()">طباعة</button>
        </div>
    </div>

    <div class="mb-6 rounded-2xl border border-slate-200 p-4">
        <div class="flex items-center justify-between gap-4">
            <div>
                <div class="text-lg font-bold">جرد سحوبات الشهر</div>
                <div class="mt-1 text-sm text-slate-600">المحل: <span class="font-semibold">@Model.StoreName</span></div>
            </div>
            <div class="text-sm">
                <div class="text-slate-600">الشهر</div>
                @{
                    var ym = Model.YearMonth;
                    var monthDate = new DateTime(ym / 100, ym % 100, 1);
                    var monthLabel = monthDate.ToString("MMMM yyyy", new CultureInfo("ar-EG"));
                    var monthLabelNumeric = monthDate.ToString("MM/yyyy");
                }
                <div class="font-bold">@monthLabel</div>
                <div class="font-mono text-xs text-slate-500">@monthLabelNumeric</div>
            </div>
        </div>
    </div>

    @{
        var receiptsByCard = Model.Receipts.GroupBy(r => r.CardId).ToDictionary(g => g.Key, g => g.OrderBy(r => r.WithdrawnAt).ToList());
        var linesByReceipt = Model.Lines.GroupBy(l => l.ReceiptId).ToDictionary(g => g.Key, g => g.ToList());
        var cardsByGroup = Model.Cards.GroupBy(c => c.GroupName).OrderBy(g => g.Key).ToList();
    }

    @foreach (var grp in cardsByGroup)
    {
        var orderedCards = grp.OrderBy(x => x.CustomerName.Trim(), StringComparer.Create(new System.Globalization.CultureInfo("ar-EG"), false)).ToList();
        int index = 1;

        <div class="mb-8">
            <div class="overflow-x-auto rounded-2xl border border-slate-200">
                <table class="w-full text-sm" style="page-break-inside: auto;">
                <thead class="bg-slate-50 text-slate-700" style="display: table-header-group;">
                    <tr>
                        <th colspan="5" class="text-center py-2 bg-white border-b border-slate-200">
                            <span class="text-xl font-bold px-6 py-1 border-2 border-slate-300 rounded-full shadow-sm">@grp.Key</span>
                        </th>
                    </tr>
                    <tr>
                        <th class="px-2 py-4 text-right font-semibold text-base" style="width: 5%;">م</th>
                        <th class="px-4 py-4 text-right font-semibold text-base" style="width: 20%;">العميل</th>
                        <th class="px-4 py-4 text-right font-semibold text-base" style="width: 55%;">المنصرف</th>
                        <th class="px-1 py-4 text-center font-semibold text-sm border-r border-slate-200 whitespace-nowrap" style="width: 10%;">تم الضرب</th>
                        <th class="px-1 py-4 text-center font-semibold text-sm border-r border-slate-200 whitespace-nowrap" style="width: 10%;">التسليم</th>
                    </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                    @foreach (var c in orderedCards)
                    {
                        var receipts = receiptsByCard.TryGetValue(c.CardId, out var rr) ? rr : new List<moa.Models.PrintMonthlyReceiptVm>();
                        decimal total = 0m;
                        var itemsAgg = new Dictionary<string, decimal[]>();

                        foreach (var r in receipts)
                        {
                            if (!linesByReceipt.TryGetValue(r.ReceiptId, out var ll)) continue;
                            foreach (var l in ll)
                            {
                                var qty = l.Quantity;
                                var price = l.UnitPrice ?? (qty == 0 ? 0m : (l.LineTotal / qty));

                                if (!itemsAgg.TryGetValue(l.ProductName, out var agg))
                                {
                                    agg = new decimal[3];
                                    itemsAgg[l.ProductName] = agg;
                                }

                                agg[0] += qty; // qty
                                agg[1] += l.LineTotal; // total
                                agg[2] += price * qty; // weighted price numerator
                                total += l.LineTotal;
                            }
                        }

                        <tr style="page-break-inside: avoid;">
                            <td class="px-4 py-4 text-slate-500 font-mono text-sm">@(index++)</td>
                            <td class="px-4 py-4 font-bold text-slate-900 text-lg">@c.CustomerName</td>
                            <td class="px-4 py-4 text-slate-700 text-sm">
                                @if (itemsAgg.Count == 0)
                                {
                                    <span>—</span>
                                }
                                else
                                {
                                    <div class="flex flex-wrap gap-x-3 gap-y-2">
                                        @foreach (var kv in itemsAgg.OrderBy(x => x.Key))
                                        {
                                            var qty = kv.Value[0];
                                            var lineTotal = kv.Value[1];
                                            var unitPrice = qty == 0 ? 0m : (kv.Value[2] / qty);

                                            <div class="flex items-center gap-x-1 text-sm whitespace-nowrap">
                                                <span class="font-semibold text-slate-800">@kv.Key</span>
                                                <span class="text-slate-500">:</span>
                                                <span class="font-mono">@qty.ToString("0.##")</span>
                                                <span class="text-slate-500">×</span>
                                                <span class="font-mono">@unitPrice.ToString("0.##")</span>
                                                <span class="text-slate-500">=</span>
                                                <span class="font-mono">@lineTotal.ToString("0.##")</span>
                                            </div>
                                        }
                                    </div>
                                }
                            </td>

                            <td class="px-4 py-4 text-center border-r border-slate-200"></td>
                            <td class="px-4 py-4 text-center border-r border-slate-200"></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    }

</div>

<script>
function exportToWord(filename = 'document.doc') {
    var preHtml = `
<html xmlns:o='urn:schemas-microsoft-com:office:office' xmlns:w='urn:schemas-microsoft-com:office:word' xmlns='http://www.w3.org/TR/REC-html40'>
<head>
    <meta charset='utf-8'>
    <title>Export HTML To Doc</title>
    <style>
        body { font-family: 'Cairo', sans-serif; direction: rtl; text-align: right; }
        table { border-collapse: collapse; width: 100%; margin-bottom: 30px; font-size: 14px; }
        th, td { border: 1px solid #000; padding: 12px; text-align: right; }
        th { background-color: #f3f4f6; font-weight: bold; font-size: 16px; }
        .text-center { text-align: center; }
        .break-after-page { page-break-after: always; }
    </style>
</head><body>
`;
    var postHtml = "</body></html>";
    
    var exportArea = document.querySelector('.mx-auto').cloneNode(true);
    var noPrints = exportArea.querySelectorAll('.no-print');
    noPrints.forEach(n => n.remove());
    
    var html = preHtml + exportArea.innerHTML + postHtml;

    var blob = new Blob(['\\ufeff', html], { type: 'application/msword' });
    var url = URL.createObjectURL(blob);
    
    var downloadLink = document.createElement("a");
    downloadLink.href = url;
    downloadLink.download = filename;
    document.body.appendChild(downloadLink);
    downloadLink.click();
    document.body.removeChild(downloadLink);
    URL.revokeObjectURL(url);
}
</script>
</body>
</html>
