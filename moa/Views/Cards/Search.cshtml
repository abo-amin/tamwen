@model moa.Models.CardSearchViewModel
@{
    ViewData["Title"] = "بحث بالاسم";
}

<div class="mx-auto max-w-4xl">
    <div class="mb-6 flex items-center justify-between gap-3">
        <div>
            <h1 class="text-2xl font-bold">بحث بالاسم</h1>
            <p class="text-sm text-slate-500">ابحث باسم صاحب البطاقة.</p>
        </div>
        <a class="rounded-xl bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-700" asp-action="Create">تسجيل بطاقة</a>
    </div>

    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
        <form asp-action="SearchResults" method="get" class="flex flex-col gap-3 md:flex-row">
            <input class="w-full rounded-xl border border-slate-200 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-200" type="text" name="name" value="@Model.Name" placeholder="اكتب الاسم هنا..." />
            <button class="rounded-xl bg-slate-900 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-slate-800" type="submit">بحث</button>
        </form>
    </div>

    <div class="mt-6 rounded-3xl border border-slate-200 bg-white shadow-sm">
        <div class="border-b border-slate-200 px-6 py-4">
            <h2 class="text-sm font-bold text-slate-700">النتائج</h2>
        </div>

        @if (Model.Results.Count == 0)
        {
            <div class="px-6 py-8 text-sm text-slate-500">لا توجد نتائج.</div>
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead class="bg-slate-50 text-slate-600">
                    <tr>
                        <th class="px-6 py-3 text-right font-semibold">الاسم</th>
                        <th class="px-6 py-3 text-right font-semibold">رقم البطاقة</th>
                        <th class="px-6 py-3 text-right font-semibold">الأفراد</th>
                        <th class="px-6 py-3"></th>
                    </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                    @foreach (var r in Model.Results)
                    {
                        <tr class="hover:bg-slate-50">
                            <td class="px-6 py-4">@r.CustomerName</td>
                            <td class="px-6 py-4 font-mono">@r.CardNumber</td>
                            <td class="px-6 py-4">@r.MembersCount</td>
                            <td class="px-6 py-4 text-left">
                                <a class="rounded-xl bg-indigo-600 px-3 py-2 text-xs font-semibold text-white shadow-sm hover:bg-indigo-700" asp-action="Details" asp-route-id="@r.CardId">فتح</a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
