@model moa.Models.CardSetPhoneViewModel
@{
    ViewData["Title"] = "رقم التليفون";
}

<div class="mx-auto max-w-xl">
    <div class="mb-6">
        <h1 class="text-2xl font-bold">تعديل رقم التليفون</h1>
        <div class="mt-1 text-sm text-slate-500">@Model.CustomerName - <span class="font-mono">@Model.CardNumber</span></div>
    </div>

    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
        <form action="@Url.Action("SetPhone", "Cards")" method="post" class="space-y-4">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="CardId" />

            <div asp-validation-summary="All" class="rounded-2xl border border-rose-200 bg-rose-50 p-3 text-sm text-rose-700"></div>

            <div>
                <label asp-for="Phone" class="mb-1 block text-sm font-semibold text-slate-700">رقم التليفون</label>
                <input asp-for="Phone" class="w-full rounded-xl border border-slate-200 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-200" />
                <span asp-validation-for="Phone" class="mt-1 block text-sm text-rose-600"></span>
            </div>

            <div class="flex items-center gap-3">
                <button type="submit" class="rounded-xl bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-700">حفظ</button>
                <a class="rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50" asp-action="Details" asp-route-id="@Model.CardId">رجوع</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
