@model moa.Models.FreeSaleDetailsViewModel
@{
    ViewData["Title"] = "تفاصيل البيع الحر";
}

<div class="mx-auto max-w-4xl">
    <div class="mb-6 flex items-center justify-between gap-3">
        <div>
            <h1 class="text-2xl font-bold">تفاصيل البيع الحر</h1>
            <p class="text-sm text-slate-500">رقم الفاتورة: @Model.FreeSaleReceiptId</p>
        </div>
        <div class="flex items-center gap-2">
            <a class="rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50" asp-controller="FreeSales" asp-action="Index">سجل البيع الحر</a>
            <a class="rounded-xl bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-700" asp-controller="FreeSales" asp-action="Create">بيع حر جديد</a>
        </div>
    </div>

    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class="grid gap-3 md:grid-cols-2">
            <div class="text-sm"><span class="font-semibold">التاريخ:</span> @Model.SoldAt</div>
            <div class="text-sm"><span class="font-semibold">الإجمالي:</span> @Model.TotalAmount</div>
        </div>
    </div>

    <div class="mt-6 rounded-3xl border border-slate-200 bg-white shadow-sm">
        <div class="border-b border-slate-200 px-6 py-4">
            <h2 class="text-sm font-bold text-slate-700">بنود الفاتورة</h2>
        </div>

        @if (Model.Items.Count == 0)
        {
            <div class="px-6 py-8 text-sm text-slate-500">لا توجد بنود.</div>
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead class="bg-slate-50 text-slate-600">
                    <tr>
                        <th class="px-6 py-3 text-right font-semibold">المنتج</th>
                        <th class="px-6 py-3 text-right font-semibold">الوحدة</th>
                        <th class="px-6 py-3 text-right font-semibold">الكمية</th>
                        <th class="px-6 py-3 text-right font-semibold">السعر</th>
                        <th class="px-6 py-3 text-right font-semibold">الإجمالي</th>
                    </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                    @foreach (var it in Model.Items)
                    {
                        <tr class="hover:bg-slate-50">
                            <td class="px-6 py-4">@it.ProductName</td>
                            <td class="px-6 py-4">@it.UnitName</td>
                            <td class="px-6 py-4">@it.Quantity</td>
                            <td class="px-6 py-4">@it.UnitPrice</td>
                            <td class="px-6 py-4 font-semibold">@it.LineTotal</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
