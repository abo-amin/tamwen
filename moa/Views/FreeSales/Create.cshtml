@model moa.Models.FreeSaleCreateViewModel
@{
    ViewData["Title"] = "بيع حر";
}

<script type="application/json" id="products-json">@Html.Raw(System.Text.Json.JsonSerializer.Serialize((IEnumerable<dynamic>)ViewBag.Products))</script>

<div class="mx-auto max-w-5xl"
     x-data="{
        products: [],
        qty: {},
        inc(pid){
            const p = (this.products || []).find(x => x.ProductId === pid);
            const onHand = p ? (p.QuantityOnHand || 0) : 0;
            const cur = (this.qty[pid] || 0);
            if (cur + 1 > onHand) return;
            this.qty[pid] = cur + 1;
        },
        dec(pid){ this.qty[pid] = Math.max(0, (this.qty[pid] || 0) - 1); },
        activeItems(){
            const items = [];
            for (const p of this.products) {
                const q = this.qty[p.ProductId] || 0;
                if (q > 0) items.push({ productId: p.ProductId, quantity: q });
            }
            return items;
        }
     }"
     x-init="products = JSON.parse(document.getElementById('products-json').textContent || '[]');">
    <div class="mb-6 flex items-center justify-between gap-3">
        <div>
            <h1 class="text-2xl font-bold">بيع حر</h1>
            <p class="text-sm text-slate-500">اختار المنتجات وكميات البيع.</p>
        </div>
        <a class="rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50" asp-controller="FreeSales" asp-action="Index">سجل البيع الحر</a>
    </div>

    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
        <form asp-action="Create" method="post" class="space-y-6">
            <div asp-validation-summary="All" class="rounded-2xl border border-rose-200 bg-rose-50 p-3 text-sm text-rose-700"></div>

            <template x-for="(it, i) in activeItems()" :key="it.productId">
                <div>
                    <input type="hidden" :name="`Items[${i}].ProductId`" :value="it.productId" />
                    <input type="hidden" :name="`Items[${i}].Quantity`" :value="it.quantity" />
                </div>
            </template>

            @{ ViewData["ProductPickerTitle"] = "اختر المنتجات"; ViewData["ProductPickerPricePrefix"] = "سعر البيع: "; }
            <partial name="_ProductPicker" />

            <div class="flex items-center gap-3">
                <button type="submit"
                        class="rounded-xl bg-indigo-600 px-5 py-3 text-sm font-semibold text-white shadow-sm hover:bg-indigo-700"
                        :disabled="activeItems().length === 0"
                        :class="(activeItems().length === 0) ? 'opacity-50 cursor-not-allowed' : ''">
                    حفظ البيع
                </button>
                <a class="rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50" asp-controller="Home" asp-action="Index">رجوع</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
